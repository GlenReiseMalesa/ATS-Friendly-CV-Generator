@page "/"
@using ATS_Friendly_CV_Generator.Models
@using ATS_Friendly_CV_Generator.Data
@inject EducationService EducationService
@inject InfoService InfoService
@inject SkillsService SkillsService
@inject ExperienceService ExperienceService
@inject DatabaseService DatabaseService
@inject NavigationManager Navigation
@using ATS_Friendly_CV_Generator.Services
@using Microsoft.EntityFrameworkCore

@using SqliteWasmHelper
@inject ISqliteWasmDbContextFactory<AppDbContext> DbFactoryContext


<PageTitle>Home</PageTitle>




<div class="app">

    <!-- ══════ LEFT: EDITOR ══════ -->
    <aside class="editor">
        <div class="section-tab">
            <button class="tab-btn @(activeTab == 1 ? "active" : "")" @onclick="() => activeTab = 1">Info</button>
            <button class="tab-btn @(activeTab == 2 ? "active" : "")" @onclick="() => activeTab = 2">Experience</button>
            <button class="tab-btn @(activeTab == 3 ? "active" : "")" @onclick="() => activeTab = 3">Education</button>
            <button class="tab-btn @(activeTab == 4 ? "active" : "")" @onclick="() => activeTab = 4">Skills</button>
        </div>



        @if (showEducationPopup == true)
        {
            <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 1000;">
                <div style="background: white; padding: 30px; border-radius: 12px; min-width: 300px;">
                    <h4>Add Education</h4>
                    <label>DEGREE</label>
                    <input type="text" style="width: 100%; padding: 8px; margin: 10px 0;" />
                    <label>INSTITUTION</label>
                    <input type="text" @bind="inputValue" style="width: 100%; padding: 8px; margin: 10px 0;" />
                    <label>DATE RANGE</label>
                    <input type="text" style="width: 100%; padding: 8px; margin: 10px 0;" />
                    <label>SUMMARY</label>
                    <textarea type="text" style="width: 100%; padding: 8px; margin: 10px 0;" />
                    <div style="display: flex; gap: 10px; margin-top: 15px;">

                        <button @onclick="CloseEducationPopup" style="padding: 6px 12px;">Cancel</button>
                        <button @onclick="CloseEducationPopup" style="padding: 6px 12px;">Submit</button>

                    </div>
                </div>
            </div>

        }








        @if (showPopup == true)
        {
            <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 1000;">
                <div style="background: white; padding: 30px; border-radius: 12px; min-width: 300px;">
                    <h4>Add Experience</h4>
                    <label>JOB TITLE</label>
                    <input type="text" style="width: 100%; padding: 8px; margin: 10px 0;" />
                    <label>COMPANY</label>
                    <input type="text" @bind="inputValue" style="width: 100%; padding: 8px; margin: 10px 0;" />
                    <label>DATE RANGE</label>
                    <input type="text" style="width: 100%; padding: 8px; margin: 10px 0;" />
                    <label>DESCRIPTION</label>
                    <textarea type="text" style="width: 100%; padding: 8px; margin: 10px 0;" />
                    <div style="display: flex; gap: 10px; margin-top: 15px;">

                        <button @onclick="CloseExperiencePopup" style="padding: 6px 12px;">Cancel</button>
                        <button @onclick="CloseExperiencePopup" style="padding: 6px 12px;">Submit</button>

                    </div>
                </div>
            </div>

        }






        @switch (activeTab)
        {
            case 1:
                @if (edittingInfoItem != null)
                {
                    <!-- PERSONAL INFO - EDIT MODE -->
                    <div id="tab-info" class="section-panel active">
                        <div class="field-group">
                            <label>Full name</label>
                            <input type="text" @bind="edittingInfoItem.FullName" id="inp-name" placeholder="Alexandra Chen">
                        </div>
                        <div class="field-group">
                            <label>Job title</label>
                            <input type="text" id="inp-title" @bind="edittingInfoItem.JobTitle" placeholder="Senior Product Designer">
                        </div>
                        <div class="field-group">
                            <label>Professional summary</label>
                            <textarea id="inp-summary" @bind="edittingInfoItem.Summary" placeholder="A brief statement..."></textarea>
                        </div>
                        <div class="two-col">
                            <div class="field-group">
                                <label>Email</label>
                                <input type="email" @bind="edittingInfoItem.Email" id="inp-email" placeholder="alex@email.com">
                            </div>
                            <div class="field-group">
                                <label>Phone</label>
                                <input type="tel" @bind="edittingInfoItem.Phone" id="inp-phone" placeholder="+1 555 000 0000">
                            </div>
                        </div>
                        <div class="two-col">
                            <div class="field-group">
                                <label>Location</label>
                                <input type="text" @bind="edittingInfoItem.Location" id="inp-location" placeholder="San Francisco, CA">
                            </div>
                            <div class="field-group">
                                <label>Website / LinkedIn</label>
                                <input type="text" @bind="edittingInfoItem.Website" id="inp-website" placeholder="linkedin.com/in/alex">
                            </div>
                        </div>
                        <div class="form-group">
                            <button class="btn btn-primary" @onclick="UpdateInfoItem" style="padding: 6px 16px;">UPDATE</button>
                        </div>
                        <div class="form-group">
                            <button class="btn btn-danger" @onclick="() => DeleteInfoItem(edittingInfoItem.Id)" style="padding: 6px 16px;">CLEAR</button>
                        </div>
                    </div>

                    Console.WriteLine("Count : " + InfoItems.Count);
                }
                else
                {
                    <!-- PERSONAL INFO - CREATE MODE -->
                    <div id="tab-info" class="section-panel active">
                        <div class="field-group">
                            <label>Full name</label>
                            <input type="text" id="inp-name" @bind="newFullName" placeholder="Alexandra Chen">
                        </div>
                        <div class="field-group">
                            <label>Job title</label>
                            <input type="text" id="inp-title" @bind="newJobTitle" placeholder="Senior Product Designer">
                        </div>
                        <div class="field-group">
                            <label>Professional summary</label>
                            <textarea id="inp-summary" @bind="newSummary" placeholder="A brief statement..."></textarea>
                        </div>
                        <div class="two-col">
                            <div class="field-group">
                                <label>Email</label>
                                <input type="email" @bind="newEmail" id="inp-email" placeholder="alex@email.com">
                            </div>
                            <div class="field-group">
                                <label>Phone</label>
                                <input type="tel" @bind="newPhone" id="inp-phone" placeholder="+1 555 000 0000">
                            </div>
                        </div>
                        <div class="two-col">
                            <div class="field-group">
                                <label>Location</label>
                                <input type="text" @bind="newLocation" id="inp-location" placeholder="San Francisco, CA">
                            </div>
                            <div class="field-group">
                                <label>Website / LinkedIn</label>
                                <input type="text" @bind="newWebsite" id="inp-website" placeholder="linkedin.com/in/alex">
                            </div>
                        </div>
                        <div class="form-group">
                            <button class="btn btn-primary" @onclick="AddInfo" style="padding: 6px 16px;">SAVE</button>
                        </div>
                    </div>
                }
                break;
            case 2:
                <!-- EXPERIENCE -->
                <div id="tab-experience" class="section-panel active">
                    <div id="exp-list"></div>
                    <button class="add-btn" @onclick="OpenExperiencePopup">+ Add experience</button>
                </div>
                break;
            case 3:
                <!-- EDUCATION -->
                <div id="tab-education" class="section-panel active">
                    <div id="edu-list"></div>
                    <button class="add-btn" @onclick="OpenEducationPopup">+ Add education</button>
                </div>
                break;
            case 4:
                <!-- SKILLS -->
                <div id="tab-skills" class="section-panel active">
                    <div class="field-group">
                        <label>Add skill</label>
                        <div class="skill-input-row">
                            <input type="text" id="skill-input" placeholder="e.g. Figma, Python, Project management" onkeydown="if(event.key==='Enter') addSkill()">
                            <button class="add-skill-btn" onclick="addSkill()">Add</button>
                        </div>
                    </div>
                    <div class="skill-tags" id="skill-tags"></div>
                </div>
                break;


        }


    </aside>



    <!-- ══════ RIGHT: PREVIEW ══════ -->
    <div class="preview-wrapper">
        <div class="cv-page" id="cv-page">

            <div class="cv-header" id="cv-header">
                <div class="cv-accent-bar" id="cv-accent-bar"></div>
                <div id="cv-name" class="cv-name" style="margin-left:1.25rem">
                    <span class="cv-placeholder">Your Name</span>
                </div>
                <div id="cv-job-title" class="cv-title" style="margin-left:1.25rem">
                    <span class="cv-placeholder">Your Title</span>
                </div>
            </div>

            <div class="cv-contact-bar" id="cv-contact-bar"></div>

            <div class="cv-body">
                <aside class="cv-sidebar">

                    <div class="cv-section" id="cv-skills-section">
                        <div class="cv-section-title" id="cv-skills-title">Skills</div>
                        <div id="cv-skills-output">
                            <span class="cv-placeholder">Add skills to see them here</span>
                        </div>
                    </div>

                    <div class="cv-section" id="cv-edu-section">
                        <div class="cv-section-title" id="cv-edu-title">Education</div>
                        <div id="cv-edu-output">
                            <span class="cv-placeholder">Add education entries</span>
                        </div>
                    </div>

                </aside>

                <main class="cv-main">

                    <div class="cv-section" id="cv-summary-section">
                        <div class="cv-section-title" id="cv-summary-title">Profile</div>
                        <div id="cv-summary-output" class="cv-summary">
                            <span class="cv-placeholder">Add a professional summary</span>
                        </div>
                    </div>

                    <div class="cv-section" id="cv-exp-section">
                        <div class="cv-section-title" id="cv-exp-title">Experience</div>
                        <div id="cv-exp-output">
                            <span class="cv-placeholder">Add your work experience</span>
                        </div>
                    </div>

                </main>
            </div>

        </div>
    </div>

</div>

<button class="print-btn">Print / Save PDF</button>

@code {

    //Page functionality
    private int activeTab = 1;
    private bool showPopup = false;
    private bool showEducationPopup = false;
    private string inputValue = "";


    private void OpenExperiencePopup()
    {
        inputValue = "";
        showPopup = true;
    }
    private void CloseExperiencePopup()
    {
        inputValue = "";
        showPopup = false;
    }

    private void OpenEducationPopup()
    {
        inputValue = "";
        showEducationPopup = true;
    }
    private void CloseEducationPopup()
    {
        inputValue = "";
        showEducationPopup = false;
    }

    //db functionality

    protected override async Task OnInitializedAsync()
    {

        await LoadInfoItems();  // Load info first
        await LoadEducationItems();
        await LoadExperienceItems();
        await LoadSkillsItems();
    }


    //Education
    private List<EducationItem> EducationItems = new();
    private string newQualification = string.Empty;
    private string newInstitution = string.Empty;
    private string newDateRange = string.Empty;
    private string newSummary = string.Empty;

    //read all
    private async Task LoadEducationItems()
    {

        await using var context = await DbFactoryContext.CreateDbContextAsync();
        EducationItems = await context.EducationItems.ToListAsync();

    }

    //add education
    private async Task AddEducation()
    {


        var education = new EducationItem
        {

            Qualification = newQualification,
            Institution = newInstitution,
            DateRange = newDateRange,
            Summary = newSummary
        };

        await using var context = await DbFactoryContext.CreateDbContextAsync();
        context.EducationItems.Add(education);
        await context.SaveChangesAsync();

        await LoadEducationItems();

    }

    //Experience
    private List<ExperienceItem> ExperienceItems = new();
    private string newJobTitle = string.Empty;
    private string newCompany = string.Empty;
    private string newDescription = string.Empty;

    //read all
    private async Task LoadExperienceItems()
    {

        await using var context = await DbFactoryContext.CreateDbContextAsync();
        ExperienceItems = await context.ExperienceItems.ToListAsync();

    }

    //add experience
    private async Task AddExperience()
    {


        var experience = new ExperienceItem
        {

            JobTitle = newJobTitle,
            Company = newCompany,
            DateRange = newDateRange,
            Description = newDescription
        };

        await using var context = await DbFactoryContext.CreateDbContextAsync();
        context.ExperienceItems.Add(experience);
        await context.SaveChangesAsync();

        await LoadExperienceItems();

    }

    //Info
    private List<InfoItem> InfoItems = new();
    private string newFullName = string.Empty;
    private string newEmail = string.Empty;
    private string newPhone = string.Empty;
    private string newLocation = string.Empty;
    private string newWebsite = string.Empty;
    private InfoItem? edittingInfoItem = null;

    //read all
    private async Task LoadInfoItems()
    {


        await using var context = await DbFactoryContext.CreateDbContextAsync();
        InfoItems = await context.InfoItems.ToListAsync();

        // Set edittingInfoItem to the first item if it exists
        if (InfoItems != null && InfoItems.Any())
        {
            edittingInfoItem = InfoItems.First();
        }
        else
        {
            edittingInfoItem = null; // No data found
           
        }

    }

    // DELETE Info Item
    private async Task DeleteInfoItem(int id)
    {

        var success = await InfoService.DeleteInfoItemAsync(id);

        await LoadInfoItems();
        StateHasChanged();

    }

    // Update Info
    private async Task UpdateInfoItem()
    {
        var success = await InfoService.UpdateInfoAsync(edittingInfoItem.Id, edittingInfoItem.FullName, edittingInfoItem.JobTitle, edittingInfoItem.Summary, edittingInfoItem.Email, edittingInfoItem.Phone, edittingInfoItem.Location, edittingInfoItem.Website);
        await LoadInfoItems();
        StateHasChanged();
    }



    //add info
    private async Task AddInfo()
    {
        
            var info = new InfoItem
                {
                    FullName = newFullName,
                    JobTitle = newJobTitle,
                    Summary = newSummary,
                    Email = newEmail,
                    Phone = newPhone,
                    Location = newLocation,
                    Website = newWebsite
                };

            await using var context = await DbFactoryContext.CreateDbContextAsync();
            context.InfoItems.Add(info);
            await context.SaveChangesAsync();
             
        await LoadInfoItems();
        StateHasChanged();

    }

    //Skills
    private List<SkillsItem> SkillsItems = new();
    private string newSkill = string.Empty;

    //read all
    private async Task LoadSkillsItems()
    {

        await using var context = await DbFactoryContext.CreateDbContextAsync();
        SkillsItems = await context.SkillsItems.ToListAsync();

    }

    //add skills
    private async Task AddSkills()
    {


        var skills = new SkillsItem
        {

            Skill = newSkill,

        };

        await using var context = await DbFactoryContext.CreateDbContextAsync();
        context.SkillsItems.Add(skills);
        await context.SaveChangesAsync();

        await LoadSkillsItems();

    }


}